{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/foxer-rpc/Dockerfile",
    "watchPatterns": [
      "apps/foxer-rpc/**",
      "packages/foxer-rpc/**",
      "package.json",
      "bun.lock",
      "tsconfig.json"
    ]
  },
  "deploy": {
    "startCommand": "bun run dist/bin/index.js start",
    "runtime": "V2",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "sleepApplication": false
  }
}
