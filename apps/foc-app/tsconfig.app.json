{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": false,
    "noEmit": true,
    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./src/*"],
      "@hugomrdias/foxer-client": ["../../packages/foxer-client/src"],
      "@hugomrdias/foxer-react": ["../../packages/foxer-react/src"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/foxer-react/tsconfig.json" },
    { "path": "../../packages/foxer-client/tsconfig.json" }
  ]
}
