{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/foc-api/Dockerfile"
  },
  "deploy": {
    "startCommand": "node packages/foxer/dist/src/bin/index.js start --root apps/foc-api --config foxer.config.ts",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
