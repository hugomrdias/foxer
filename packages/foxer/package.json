{
  "name": "@hugomrdias/foxer",
  "version": "0.1.3",
  "description": "Foxer is a all-in-one application server for Filecoin.",
  "license": "Apache-2.0 OR MIT",
  "author": "Hugo Dias <hugomrdias@gmail.com>",
  "repository": {
    "url": "hugomrdias/foxer",
    "directory": "packages/foxer"
  },
  "bin": {
    "foxer": "./dist/src/bin/index.js"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "typesVersions": {
    "*": {
      "api": [
        "./src/api/index"
      ],
      "schema": [
        "./src/schema"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./api": {
      "types": "./dist/src/api/index.d.ts",
      "default": "./dist/src/api/index.js"
    },
    "./schema": {
      "types": "./dist/src/schema.d.ts",
      "default": "./dist/src/schema.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "vp lint && vp fmt",
    "build": "tsc --build",
    "prepublishOnly": "vp run build",
    "prepare": "vp run build"
  },
  "dependencies": {
    "@bluwy/giget-core": "^0.1.6",
    "@clack/prompts": "^1.1.0",
    "@electric-sql/pglite": "^0.3.16",
    "@hono/node-server": "^1.19.11",
    "@libpg-query/parser": "^17.6.3",
    "@pgsql/traverse": "^17.2.4",
    "abitype": "^1.2.3",
    "cleye": "^2.3.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "exit-hook": "^5.1.0",
    "hono": "^4.12.7",
    "hono-pino": "^0.10.3",
    "http-shutdown": "^1.2.2",
    "lilconfig": "^3.1.3",
    "p-queue": "^9.1.0",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "scule": "^1.3.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@pgsql/types": "^17.6.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "hono": ">=4.5",
    "viem": "2.x"
  }
}
