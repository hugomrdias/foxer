{
  "name": "@hugomrdias/foxer-client",
  "version": "0.1.0",
  "description": "React hooks for interacting with Filecoin Onchain Cloud smart contracts",
  "keywords": [
    "filecoin",
    "filecoin onchain cloud",
    "filecoin pay",
    "hooks",
    "react",
    "synapse",
    "web3"
  ],
  "homepage": "https://github.com/hugomrdias/foxer/tree/main/packages/foxer-client",
  "bugs": {
    "url": "https://github.com/hugomrdias/foxer/issues"
  },
  "license": "Apache-2.0 OR MIT",
  "author": "Hugo Dias <hugomrdias@gmail.com>",
  "repository": {
    "url": "hugomrdias/foxer",
    "directory": "packages/foxer-client"
  },
  "files": [
    "src",
    "dist/src",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "tsc --noEmit && biome check .",
    "build": "tsc --build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "drizzle-orm": "1.0.0-beta.18-905b79a",
    "eventsource": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "type-fest": "^5.4.4",
    "typescript": "5.9.3",
    "viem": "2.47.4"
  },
  "peerDependencies": {
    "viem": "2.x"
  }
}
