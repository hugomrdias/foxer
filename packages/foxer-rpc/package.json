{
  "name": "@hugomrdias/foxer-rpc",
  "version": "0.0.0",
  "description": "Full-chain sync with a minimal Ethereum JSON-RPC API.",
  "license": "Apache-2.0 OR MIT",
  "author": "Hugo Dias <hugomrdias@gmail.com>",
  "repository": {
    "url": "hugomrdias/foxer",
    "directory": "packages/foxer-rpc"
  },
  "bin": {
    "foxer-rpc": "./dist/bin/index.js",
    "foxer-rpc.src": "./src/bin/index.ts"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "generate": "drizzle-kit generate",
    "check": "tsc --noEmit && biome check .",
    "test": "bun test --preload ./test/setup.ts ./test/",
    "build": "tsc -b",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@hono/node-server": "^2.0.8",
    "cleye": "^2.6.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "1.0.0-rc.4",
    "exit-hook": "^5.1.0",
    "hono": "^4.12.29",
    "hono-compress": "^1.0.2",
    "hono-pino": "^0.10.3",
    "http-shutdown": "^1.2.2",
    "iso-base": "^4.4.0",
    "p-queue": "^9.3.1",
    "pg": "^8.22.0",
    "pg-copy-streams": "^7.0.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "drizzle-kit": "1.0.0-rc.4",
    "msw": "^2.15.0",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "hono": ">=4.12.29",
    "viem": "^2.55.0"
  },
  "engines": {
    "node": ">=22.15"
  }
}
