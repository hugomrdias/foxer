{
  "name": "@hugomrdias/foxer-react",
  "version": "0.1.2",
  "description": "React hooks for interacting with Filecoin Onchain Cloud smart contracts",
  "keywords": [
    "filecoin",
    "filecoin onchain cloud",
    "filecoin pay",
    "hooks",
    "react",
    "synapse",
    "web3"
  ],
  "homepage": "https://github.com/hugomrdias/foxer/tree/main/packages/foxer-react",
  "bugs": {
    "url": "https://github.com/hugomrdias/foxer/issues"
  },
  "license": "Apache-2.0 OR MIT",
  "author": "Hugo Dias <hugomrdias@gmail.com>",
  "repository": {
    "url": "hugomrdias/foxer",
    "directory": "packages/foxer-react"
  },
  "files": [
    "src",
    "dist/src",
    "dist/src/**/*.d.ts",
    "dist/src/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "tsc --noEmit && biome check .",
    "build": "tsc -b",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@hugomrdias/foxer-client": "workspace:^",
    "drizzle-orm": "1.0.0-beta.17-67b1795"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": "5.95.1",
    "react": ">=18"
  }
}
